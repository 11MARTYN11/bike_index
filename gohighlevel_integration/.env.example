# ==========================================
# BIKE INDEX TO GO HIGH LEVEL INTEGRATION
# ==========================================

# ==========================================
# BIKE INDEX API CONFIGURATION
# ==========================================
BIKE_INDEX_API_KEY=your_bike_index_api_key_here

# Bike Index OAuth Configuration
BIKE_INDEX_OAUTH_CLIENT_ID=your_bike_index_oauth_client_id
BIKE_INDEX_OAUTH_CLIENT_SECRET=your_bike_index_oauth_client_secret

# Bike Index Redirect URIs (one per line)
# Add these to your Bike Index OAuth Application Settings
BIKE_INDEX_OAUTH_REDIRECT_URI_1=http://localhost:3000/auth/bike-index/callback
BIKE_INDEX_OAUTH_REDIRECT_URI_2=urn:ietf:wg:oauth:2.0:oob
BIKE_INDEX_OAUTH_REDIRECT_URI_3=bikeindex://oauth-callback
BIKE_INDEX_OAUTH_REDIRECT_URI_4=https://bikeindex.org/documentation/authorize

# ==========================================
# GO HIGH LEVEL CRM API CONFIGURATION
# ==========================================
GHL_API_KEY=your_gohighlevel_api_key_here
GHL_LOCATION_ID=your_location_id_here

# Go High Level OAuth Configuration
GHL_OAUTH_CLIENT_ID=your_ghl_oauth_client_id
GHL_OAUTH_CLIENT_SECRET=your_ghl_oauth_client_secret

# Go High Level Redirect URIs (one per line)
# Add these to your Go High Level OAuth Application Settings
GHL_OAUTH_REDIRECT_URI_1=http://localhost:3000/auth/ghl/callback
GHL_OAUTH_REDIRECT_URI_2=urn:ietf:wg:oauth:2.0:oob
GHL_OAUTH_REDIRECT_URI_3=https://app.gohighlevel.com/oauth/callback

# ==========================================
# JWT & AUTHENTICATION CONFIGURATION
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=30d

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000

# ==========================================
# SYNC CONFIGURATION
# ==========================================
# Sync intervals in milliseconds
SYNC_INTERVAL=3600000
STOLEN_BIKES_CHECK_INTERVAL=1800000
ORGANIZATIONS_SYNC_INTERVAL=86400000

# ==========================================
# WEBHOOK CONFIGURATION
# ==========================================
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_PORT=3000

# ==========================================
# SESSION MANAGEMENT
# ==========================================
SESSION_EXPIRY=86400000
SESSION_STORAGE_PATH=./data/sessions/

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=info
LOG_FILE=./logs/integration.log

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ==========================================
# MONITORING & ALERTS
# ==========================================
ENABLE_MONITORING=true
ALERT_EMAIL=your-email@example.com
